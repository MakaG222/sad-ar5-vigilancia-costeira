# Copiar para .env (setup-mac.sh / setup-win.ps1 fazem isto automaticamente se o ficheiro existir)
#
# --- AIS em tempo real (opcional) ---
# Chave gratuita em https://aisstream.io — sem chave, a plataforma usa navios simulados.
# AISSTREAM_API_KEY=
#
# --- Portas (opcional; valores por omissão) ---
# API_PORT=8080
# WEB_PORT=5173
#
# --- Demo determinístico (recomendado na defesa) ---
# Navios e meteo fixos — mesma demo em cada arranque
# DEMO_DETERMINISTICO=1
